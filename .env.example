# Stripe
# Récupérer sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Récupérer dans Stripe Dashboard → Webhooks → votre endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# ID du prix annuel Pro dans Stripe Dashboard → Products
STRIPE_PRICE_PRO=price_...

# Admin
# Clé secrète pour l'API admin des licences — générer avec: openssl rand -hex 32
ADMIN_API_KEY=isomorph-admin-secret-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
